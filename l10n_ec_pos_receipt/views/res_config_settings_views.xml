<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.l10n_ec_pos_receipt</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_accounting_section']" position="inside">
                <setting id="l10n_ec_print_edi_receipt" string="Facturación Electrónica en Ticket" help="Imprimir información de la Factura Electrónica (Clave de Acceso SRI) en el recibo del Punto de Venta.">
                    <field name="pos_l10n_ec_print_edi_receipt"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
