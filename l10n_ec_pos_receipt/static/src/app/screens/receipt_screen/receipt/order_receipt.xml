<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="l10n_ec_pos_receipt.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('before-footer')]" position="before">
            <t t-if="props.data.l10n_ec_xml_access_key and props.data.l10n_ec_print_edi_receipt">
                <br/>
                <div class="pos-receipt-center-align" style="font-weight: bold; margin-top: 5px;">
                    FACTURA ELECTRÓNICA
                </div>
                <!-- Optional Document Number if requested -->
                <t t-if="props.data.l10n_latam_document_number">
                    <div class="pos-receipt-center-align">
                        <t t-esc="props.data.l10n_latam_document_number"/>
                    </div>
                </t>
                <div style="font-size: 80%; text-align: center; margin-top: 5px;">
                    <div><strong>CLAVE DE ACCESO:</strong></div>
                    <div style="word-break: break-all; margin: 3px 0;">
                        <t t-esc="props.data.l10n_ec_xml_access_key"/>
                    </div>
                    <div>
                        <t t-if="props.data.company_env == '1'">
                            Ambiente: Pruebas
                        </t>
                        <t t-elif="props.data.company_env == '2'">
                            Ambiente: Producción
                        </t>
                    </div>
                </div>
                <br/>
            </t>
        </xpath>
    </t>
</templates>
